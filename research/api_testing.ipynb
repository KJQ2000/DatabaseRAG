    "## ensure backend api is running ('uvicorn api:app --port 8000')\n",
    "import requests\n",
    "\n",
    "url = \"http://localhost:8000/ask\"\n",
    "\n",
    "payload = {\n",
    "    \"question\": \"How many rings are currently in stock? stk_type = RING\"\n",
    "}\n",
    "\n",
    "response = requests.post(url, json=payload)\n",
    "\n",
    "print(response.json())"
   ]
  }
